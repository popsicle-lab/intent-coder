// ============================================================
// Acceptance Intent Seed — {slug}
// ============================================================
//
// Generated by:    prd-writer skill
// Target Product:  {target_product}
// Source PRD:      {slug}.prd.md
// Source PDR:      PDR-{id}-{slug}.md
// Generation Date: {YYYY-MM-DD}
//
// ⚠️ 本文件是 **种子**（seed），不是终态 intent：
//   - 语法宽松，目的是让 LLM 和人类都能快速理解和编辑
//   - 最终的语法收紧由项目自带的 intent spec writer 完成
//   - Z3 验证由 intent-coder 的 intent-consistency-check skill 完成
//   - 合并目标：products/{target_product}/intents/acceptance.intent
//     （**单文件**，所有 acceptance block 都在一个 .intent 里，便于 Z3 跨块求解）
//
// 本文件只包含 **acceptance.intent 层** 的内容（PRD § Intent Mapping 中标了
// `acceptance.intent` 的条目）。标了 invariants / contracts 的条目**不**进本
// 文件——分别由项目自带 spec writer 处理，或等 ADR 落地后处理。
//
// ============================================================
// Block 命名契约（重要）
// ============================================================
//
// 每个 acceptance block 的名字 **必须**遵循以下规则：
//
//   <task_id>-<short-description-kebab>
//
// 例：T-0001-response-under-5s
//     T-0010-batch-mode-no-partial-fail
//
// 这是 task ↔ intent block ↔ 未来 e2e 测试三者的唯一连接键。
//
// **不允许**的命名形式：
//   - `verification_response_under_5s`     ← 没有 task_id，溯源链断
//   - `T-0001`                              ← 缺描述，多个 block 同一 task 时冲突
//   - `T0001_response`                      ← 下划线（请用 kebab-case）
//
// ============================================================
// Block 标准结构
// ============================================================
//
//   acceptance "<task_id>-<short-description>" {
//     task:          <task_id>                  // 必填，与 task 文件 frontmatter 一致
//     pdr:           PDR-XXXX                   // 必填，决策来源
//     source:        prd § <章节路径>            // 必填，PRD 中对应原文位置
//     journey_stage: onboarding | daily-ops | ... // 必填，与 task 同
//     query_anchors: [                          // 必填，至少 1 个用户原话问句
//       "...",
//     ]
//
//     given:         <初始条件 / 上下文>
//     when:          <触发动作>
//     then:          <可观察的预期行为，含硬约束>
//   }
//
// `then` 中支持的硬约束词汇（intent-consistency-check 会识别这些）：
//   - within(<duration>, <event>)        // 时间上限
//   - at_least(<n>, <unit>)               // 数量下限
//   - at_most(<n>, <unit>)                // 数量上限
//   - eventually(<event>)                 // 最终可达
//   - never(<event>)                      // 永不发生
//   - forall(<var> in <set>, <predicate>) // 全称量化
//   - exists(<var> in <set>, <predicate>) // 存在量化
//
// ============================================================


// ---- Block 1: T-0001 — 首次验证 5 秒内反馈 ----
acceptance "T-0001-response-under-5s" {
  task:          T-0001
  pdr:           PDR-{id}
  source:        prd § "Intent Mapping" › row 1
  journey_stage: onboarding
  query_anchors: [
    "怎么第一次跑 intent check？",
    "5 秒内没结果是不是卡死了？",
    "跑 intent check 多久能拿到反馈？"
  ]

  given:  user.has(intent_file) && user.tier == free && user.installed(cli, >= 0.2)
  when:   cli.invokes(verifier.Verify(spec = intent_file))
  then:   within(5.seconds, user.sees(PASS or FAIL))
}


// ---- Block 2: T-0002 — FAIL 时含可读最短反例 ----
acceptance "T-0002-counterexample-minimal" {
  task:          T-0002
  pdr:           PDR-{id}
  source:        prd § "Intent Mapping" › row 2
  journey_stage: onboarding
  query_anchors: [
    "拿到 FAIL 怎么看反例？",
    "反例怎么读？"
  ]

  given:  verifier.returned(FAIL)
  when:   user.requests(counterexample)
  then:   counterexample.is_minimal && counterexample.fits_in(80.columns * 40.lines)
}


// ---- Block 3: T-0010 — 批量模式不允许部分失败 ----
acceptance "T-0010-batch-mode-no-partial-fail" {
  task:          T-0010
  pdr:           PDR-{id}
  source:        prd § "Intent Mapping" › row 3
  journey_stage: daily-ops
  query_anchors: [
    "怎么一次校验一堆 .intent？",
    "批量验证里有一个失败其它的算什么？"
  ]

  given:  user.submits(intent_files: List[IntentFile], count >= 2)
  when:   cli.invokes(verifier.BatchVerify(specs = intent_files))
  then:   forall(f in intent_files,
                 eventually(verifier.returns_for(f, PASS or FAIL)))
       && never(verifier.skips(any of intent_files))
}


// ============================================================
// 一致性自检（prd-writer 在 review 状态前必跑）
// ============================================================
//
//   1. 本文件 block 数  ==  PRD § Intent Mapping 表中标 `acceptance.intent` 的行数
//   2. 每个 block 的 `task:` 字段都对应一个存在的 task 文件
//      （`products/{target_product}/tasks/{journey_stage}/T-XXXX-*.md`）
//   3. 每个 block 的 `journey_stage` 与对应 task 文件 frontmatter 的 journey_stage 一致
//   4. 每个 block 的 `query_anchors` 至少 1 个出现在 PRD § User Intents Catalog 中
//   5. 每个 task 文件的 frontmatter `related_intents` 字段，反向引用了本文件的对
//      应 block 名
//
// 任一项失败 → 退回 drafting。
//
// ============================================================
// 合并到 products/{target_product}/intents/acceptance.intent
// ============================================================
//
// 这是**单文件**——所有 acceptance block 共住一个 .intent，便于 Z3 跨块求解
// 跨 task 的逻辑一致性。
//
// 合并步骤：
//   1. 项目自带 intent spec writer 收紧本种子语法（去注释、规范关键词）
//   2. 检查与已有 block 是否冲突（block 名重复、then 互相否定）
//   3. 追加到 products/{target_product}/intents/acceptance.intent 末尾
//   4. 跑 intent-consistency-check（上线后）做 Z3 闸
//
